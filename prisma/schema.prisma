generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MediaAssetKind {
  image
  video
}

enum PromotionTriggerType {
  automatic
  coupon
}

enum PromotionRuleType {
  buy_x_get_y
  nth_item_percentage
  volume_discount
  free_shipping
}

enum PromotionStackingMode {
  exclusive
  stackable
}

model ContactLead {
  id        String   @id @default(cuid())
  fullName  String
  email     String
  phone     String?
  message   String
  source    String   @default("web-form")
  status    String   @default("new")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([status])
  @@index([createdAt])
}

model MediaAsset {
  id                    String            @id @default(cuid())
  storageKey            String            @unique
  publicUrl             String?
  kind                  MediaAssetKind
  mimeType              String?
  altText               String?
  posterUrl             String?
  width                 Int?
  height                Int?
  durationSeconds       Int?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  primaryHeroHomePages  HomePageContent[] @relation("HomePrimaryHeroMedia")
  secondaryHeroHomePages HomePageContent[] @relation("HomeSecondaryHeroMedia")
  tertiaryHeroHomePages HomePageContent[] @relation("HomeTertiaryHeroMedia")
  categoryCards         Category[]        @relation("CategoryMediaAsset")
  productCards          Product[]         @relation("ProductMediaAsset")
  brandLogos            Brand[]           @relation("BrandLogoMediaAsset")

  @@index([kind])
  @@index([createdAt])
}

model Category {
  id              String                 @id @default(cuid())
  slug            String                 @unique
  name            String
  description     String
  href            String
  isActive        Boolean                @default(true)
  mediaAssetId    String?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  mediaAsset      MediaAsset?            @relation("CategoryMediaAsset", fields: [mediaAssetId], references: [id], onDelete: SetNull)
  products        Product[]
  productAssignments ProductCategoryAssignment[]
  promotionScopes PromotionCategory[]
  homeSelections  HomeFeaturedCategory[]

  @@index([isActive])
  @@index([mediaAssetId])
  @@index([createdAt])
}

model Product {
  id                 String                @id @default(cuid())
  slug               String                @unique
  name               String
  brand              String                @default("Sin marca")
  brandId            String?
  description        String
  href               String
  badge              String?
  badgeColor         String?
  price              Decimal               @default(0) @db.Decimal(10, 2)
  discountPrice      Decimal?              @db.Decimal(10, 2)
  stock              Int                   @default(0)
  isActive           Boolean               @default(true)
  categoryId         String?
  mediaAssetId       String?
  
  // Sync tracking
  externalId         String?               @unique
  externalSourceId   String?               // Origin system identifier (e.g., "shopify", "custom-api")
  lastSyncedAt       DateTime?
  syncVersion        Int                   @default(0)
  externalMetadata   Json?                 // Store raw external data for audit/enrichment
  
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  brandRecord        Brand?                @relation(fields: [brandId], references: [id], onDelete: SetNull)
  category           Category?             @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  categoryAssignments ProductCategoryAssignment[]
  mediaAsset         MediaAsset?           @relation("ProductMediaAsset", fields: [mediaAssetId], references: [id], onDelete: SetNull)
  promotionScopes    PromotionProduct[]
  homeSelections     HomeFeaturedProduct[]

  @@index([isActive])
  @@index([categoryId])
  @@index([mediaAssetId])
  @@index([createdAt])
  @@index([externalId])
  @@index([externalSourceId])
  @@index([lastSyncedAt])
  @@index([brandId])
}

model Brand {
  id          String     @id @default(cuid())
  name        String     @unique
  mediaAssetId String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  mediaAsset  MediaAsset? @relation("BrandLogoMediaAsset", fields: [mediaAssetId], references: [id], onDelete: SetNull)
  products    Product[]
  promotionScopes PromotionBrand[]

  @@index([mediaAssetId])
  @@index([createdAt])
}

model ProductCategoryAssignment {
  productId   String
  categoryId  String
  position    Int      @default(0)
  createdAt   DateTime @default(now())
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  category    Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([productId, categoryId])
  @@index([categoryId])
  @@index([productId, position])
}

model ProductBadgePreset {
  id        String   @id @default(cuid())
  label     String   @unique
  color     String
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
  @@index([sortOrder])
  @@index([createdAt])
}

model Promotion {
  id             String                @id @default(cuid())
  name           String
  description    String?
  isActive       Boolean               @default(true)
  triggerType    PromotionTriggerType  @default(automatic)
  couponCode     String?               @unique
  ruleType       PromotionRuleType
  stackingMode   PromotionStackingMode @default(exclusive)
  priority       Int                   @default(0)
  startsAt       DateTime?
  endsAt         DateTime?
  config         Json
  productScopes  PromotionProduct[]
  categoryScopes PromotionCategory[]
  brandScopes    PromotionBrand[]
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  @@index([isActive, triggerType])
  @@index([priority])
  @@index([startsAt, endsAt])
  @@index([createdAt])
}

model PromotionProduct {
  promotionId String
  productId   String
  createdAt   DateTime  @default(now())
  promotion   Promotion @relation(fields: [promotionId], references: [id], onDelete: Cascade)
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([promotionId, productId])
  @@index([productId])
  @@index([promotionId])
}

model PromotionCategory {
  promotionId String
  categoryId  String
  createdAt   DateTime  @default(now())
  promotion   Promotion @relation(fields: [promotionId], references: [id], onDelete: Cascade)
  category    Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([promotionId, categoryId])
  @@index([categoryId])
  @@index([promotionId])
}

model PromotionBrand {
  promotionId String
  brandId     String
  createdAt   DateTime  @default(now())
  promotion   Promotion @relation(fields: [promotionId], references: [id], onDelete: Cascade)
  brand       Brand     @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@id([promotionId, brandId])
  @@index([brandId])
  @@index([promotionId])
}

model HomeFeaturedCategory {
  id                String          @id @default(cuid())
  homePageContentId String
  categoryId        String
  position          Int
  createdAt         DateTime        @default(now())
  homePageContent   HomePageContent @relation(fields: [homePageContentId], references: [id], onDelete: Cascade)
  category          Category        @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([homePageContentId, categoryId])
  @@unique([homePageContentId, position])
  @@index([categoryId])
}

model HomeFeaturedProduct {
  id                String          @id @default(cuid())
  homePageContentId String
  productId         String
  position          Int
  createdAt         DateTime        @default(now())
  homePageContent   HomePageContent @relation(fields: [homePageContentId], references: [id], onDelete: Cascade)
  product           Product         @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([homePageContentId, productId])
  @@unique([homePageContentId, position])
  @@index([productId])
}

model HomePageContent {
  id                           String      @id @default(cuid())
  slug                         String      @unique @default("home")
  heroEyebrow                  String
  heroTitle                    String
  heroSubtitle                 String
  heroSupportingBadge          String
  heroPrimaryCtaText           String
  heroPrimaryCtaHref           String
  heroSecondaryCtaText         String?
  heroSecondaryCtaHref         String?
  heroMediaId                  String?
  heroSecondaryMediaId         String?
  heroTertiaryMediaId          String?
  featuredCategoriesEyebrow    String
  featuredCategoriesTitle      String
  featuredCategorySelections   HomeFeaturedCategory[]
  featuredProductSelections    HomeFeaturedProduct[]
  featuredCategoriesDescription String
  featuredCategoriesItems      Json
  featuredProductsEyebrow      String
  featuredProductsTitle        String
  featuredProductsDescription  String
  featuredProductsItems        Json
  trustHighlightsEyebrow       String
  trustHighlightsTitle         String
  trustHighlightsDescription   String
  trustHighlightsItems         Json
  ctaEyebrow                   String
  ctaTitle                     String
  ctaDescription               String
  ctaPrimaryCtaText            String
  ctaPrimaryCtaHref            String
  ctaSecondaryCtaText          String?
  ctaSecondaryCtaHref          String?
  createdAt                    DateTime    @default(now())
  updatedAt                    DateTime    @updatedAt
  heroMedia                    MediaAsset? @relation("HomePrimaryHeroMedia", fields: [heroMediaId], references: [id], onDelete: SetNull)
  heroSecondaryMedia           MediaAsset? @relation("HomeSecondaryHeroMedia", fields: [heroSecondaryMediaId], references: [id], onDelete: SetNull)
  heroTertiaryMedia            MediaAsset? @relation("HomeTertiaryHeroMedia", fields: [heroTertiaryMediaId], references: [id], onDelete: SetNull)

  @@index([heroMediaId])
  @@index([heroSecondaryMediaId])
  @@index([heroTertiaryMediaId])
  @@index([createdAt])
}
