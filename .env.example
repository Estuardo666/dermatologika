# ===============================================
# DATABASE CONFIGURATION
# ===============================================
# PostgreSQL connection string for Prisma
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
# 
# Example local development:
#   postgresql://postgres:your_password@localhost:5432/dermatologika_dev?schema=public
#
# Example production (Neon):
#   postgresql://user:password@ep-xxxxx.us-east-2.aws.neon.tech/dermatologika?schema=public&sslmode=require
#
# IMPORTANT:
# - This value is SERVER-ONLY (never exposed to client)
# - Validated in src/config/env.ts with Zod
# - Read via environment variable on server startup
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/dermatologika?schema=public"

# ===============================================
# RUNTIME ENVIRONMENT
# ===============================================
# Valid values: development | test | production
NODE_ENV="development"

# ===============================================
# INTERNAL ADMIN AUTHORIZATION
# ===============================================
# Server-side credentials used by the admin login endpoint.
# The session secret signs the httpOnly cookie for protected admin API access.
ADMIN_AUTH_EMAIL="admin@dermatologika.local"
ADMIN_AUTH_PASSWORD="change-this-admin-password"
STAFF_AUTH_EMAIL="staff@dermatologika.local"
STAFF_AUTH_PASSWORD="change-this-staff-password"
AUTH_SESSION_SECRET="change-this-session-secret-with-at-least-32-characters"
AUTH_SESSION_MAX_AGE_SECONDS="28800"

